# PostgreSQL (local: see repo-root docker-compose.yml)
DATABASE_URL="postgresql://anang:anang@localhost:5432/anang?schema=public"

# Auth.js — required for any deploy (signing sessions). Generate: openssl rand -base64 32
AUTH_SECRET="replace-with-long-random-string"
# Optional: HMAC secret for patient magic links (/p/{org}/pay/...). Defaults to AUTH_SECRET if unset.
# PATIENT_PAY_LINK_SECRET="separate-from-auth-secret-optional"
# Optional: skip DOB/account step-up on patient pay (demos only — not for production PHI).
# DISABLE_PATIENT_PAY_STEPUP=1

# Canonical public origin of this app (Vercel: https://app.anang.ai). Aids OAuth redirects.
# AUTH_URL="http://localhost:3001"

# Optional enterprise SSO (OpenID Connect). When issuer + id + secret are set, /login can show platform SSO.
# Register redirect URL: {AUTH_URL}/api/auth/callback/oidc
# AUTH_OIDC_ISSUER="https://login.microsoftonline.com/{tenant-id}/v2.0"
# AUTH_OIDC_ID="application-client-id"
# AUTH_OIDC_SECRET="application-client-secret"
# AUTH_OIDC_NAME="Sign in with Microsoft"
#
# Per-tenant OIDC (preferred for production): issuer + client id live in Tenant.settings (admin UI).
# Secret only here — name is derived from tenant slug, e.g. slug hayward →:
# AUTH_OIDC_CLIENT_SECRET__HAYWARD="customer-app-registration-secret"
# Callback to register on the IdP: {AUTH_URL}/api/auth/tenant-oidc/hayward/callback

# Staging / pilot sign-in (password path; works alongside SSO).
# Virtual email (optional): same PLATFORM_LOGIN_PASSWORD as other pilot users; defaults to LCO admin if used without API accessProfile.
PLATFORM_LOGIN_PASSWORD="change-me-in-deploy"
PLATFORM_VIRTUAL_EMAIL="support@anang.ai"
NEXT_PUBLIC_PLATFORM_VIRTUAL_EMAIL="support@anang.ai"

# DEV ONLY: grant every module and ignore staff module allow-lists (never in production).
# ANANG_UNLOCK_ALL_MODULES=1

# Legacy names (still read by the app if PLATFORM_* unset)
# DEMO_LOGIN_EMAIL="support@anang.ai"
# DEMO_LOGIN_PASSWORD="change-me-in-deploy"
# NEXT_PUBLIC_DEMO_LOGIN_EMAIL="support@anang.ai"

# Optional: used when tightening cookies / future JWT
# SESSION_SECRET="generate-a-long-random-string"

# Public URLs (Vercel)
# NEXT_PUBLIC_ANANG_DOMAIN=anang.ai
# NEXT_PUBLIC_ANANG_APP_HOST=app.anang.ai

# --- Synthetic dataset import (prisma/import-realistic-xlsx.ts) ---
# Optional path overrides; default is %USERPROFILE%\Downloads\ on Windows.
# REALISTIC_CLAIMS_XLSX=...
# REALISTIC_ENCOUNTERS_XLSX=...
# REALISTIC_LINES_XLSX=...
# REALISTIC_PATIENT_DEMOGRAPHICS_XLSX=...
# REALISTIC_REMITTANCE_XLSX=...
# IMPORT_TENANT_SLUG=synthetic-test

# --- Optional integration hooks (see Tenant settings “Integration readiness”) ---
# Stripe (test mode recommended): checkout + POST /api/webhooks/stripe
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# Base URL for Checkout redirect (production). Falls back to VERCEL_URL or localhost.
# NEXT_PUBLIC_APP_ORIGIN=https://app.anang.ai
# ANANG_PAYMENTS_LIVE=0
# EHR_FHIR_CLIENT_ID=
#
# --- Greenway Health FHIR R4 (server-side; optional until pilot credentials exist) ---
# Docs: https://developers.greenwayhealth.com/developer-platform/reference/getting-started-1
# Prefer customer-specific base URL when listed under "FHIR base URLs" in their portal.
# GREENWAY_FHIR_BASE_URL="https://fhir-api.fhirstaging.aws.greenwayhealth.com/fhir/R4/YOUR_TENANT_ID"
# Or build default host from tenant + environment:
# GREENWAY_FHIR_ENV=staging
# GREENWAY_FHIR_TENANT_ID=YOUR_TENANT_ID
# Bearer (manual) and/or OAuth2 client_credentials (when static token unset):
# GREENWAY_FHIR_ACCESS_TOKEN=
# GREENWAY_FHIR_CLIENT_ID=
# GREENWAY_FHIR_CLIENT_SECRET=
# GREENWAY_FHIR_TOKEN_URL=https://...   # Greenway Identity token endpoint for this app registration
# GREENWAY_FHIR_OAUTH_SCOPE=            # optional — if your registration requires scopes
# Aliases accepted: EHR_FHIR_BASE_URL, EHR_FHIR_TENANT_ID, EHR_FHIR_ENV, EHR_FHIR_ACCESS_TOKEN
#
# Per-tenant Greenway (slug `lco` → env suffix `__LCO`; same pattern as AUTH_OIDC_CLIENT_SECRET__*):
# GREENWAY_FHIR_ACCESS_TOKEN__LCO=
# GREENWAY_FHIR_CLIENT_ID__LCO=  … CLIENT_SECRET, TOKEN_URL, OAUTH_SCOPE likewise
# Non-secret routing: Tenant.settings JSON `connectors.greenwayFhir`: { "fhirTenantId", "hostEnv", optional "baseUrl" } — see DEPLOYMENT.md
#
# Cron: GET or POST /api/cron/greenway-fhir-sync with Authorization: Bearer <same value>
# Vercel: set CRON_SECRET in the project; scheduled crons send Authorization: Bearer automatically.
# Optional bulk backfill (no ?patientId): comma/semicolon-separated FHIR Patient ids, max 30 — runs when tenant slug is set below.
# GREENWAY_FHIR_CRON_PATIENT_IDS=id1,id2
# Optional: ?patientId=…&tenantSlug=lco upserts into that tenant (or set GREENWAY_FHIR_SYNC_TENANT_SLUG as default slug).
# Without tenantSlug/sync slug: ?patientId=… is probe-only (PHI — BAA staging only).
# GREENWAY_FHIR_SYNC_TENANT_SLUG=lco
# CRON_SECRET=generate-a-long-random-string
#
# Optional — Patient Pay SMS (Twilio). Staff “Text link” on statement detail.
# TWILIO_ACCOUNT_SID=AC...
# TWILIO_AUTH_TOKEN=...
# Use either a messaging service (recommended) or a From number (E.164):
# TWILIO_MESSAGING_SERVICE_SID=MG...
# TWILIO_FROM_NUMBER=+15551234567
#
# Patient /p/* — /patient-manifest.json references /patient-billing-icon-192.png and /patient-billing-icon-512.png (in public/).
# Optional Web Push (requires legal/care review): same value on server + client bundle.
# NEXT_PUBLIC_PATIENT_WEB_PUSH_ENABLED=1
# Generate keys: npx web-push generate-vapid-keys — put public in NEXT_PUBLIC_*, private in PATIENT_WEB_PUSH_VAPID_PRIVATE_KEY (for future send worker only; subscribe route does not need private).
# NEXT_PUBLIC_PATIENT_WEB_PUSH_VAPID_PUBLIC_KEY=...
# PATIENT_WEB_PUSH_VAPID_PRIVATE_KEY=...
# Per-tenant SMS: Tenant.settings JSON messaging.smsQuietHours + messaging.twilio (subaccount) — see DEPLOYMENT.md.
# Transactional email (optional): invite links from /admin — Resend preferred, else SendGrid
# RESEND_API_KEY=re_...
# RESEND_FROM_EMAIL="Invites <invites@yourdomain.com>"
# SENDGRID_API_KEY=
# SENDGRID_FROM_EMAIL=invites@yourdomain.com
# CLEARINGHOUSE_API_KEY=
# Inbound X12 (277 / 835 / 997 / 999): POST /api/webhooks/clearinghouse — JSON { tenantSlug, x12 }
# Stores IngestionBatch + SourceArtifact (SHA-256 always); inline raw X12 uses same byte cap as FHIR: FHIR_IMPORT_MAX_INLINE_PAYLOAD_BYTES
# CLEARINGHOUSE_WEBHOOK_SECRET=generate-a-long-random-string
#
# Outbound 837 pilot HTTP (optional; Connect claim detail — checkbox when enabled)
# EDI_OUTBOUND_HTTP_ENABLED=true
# EDI_OUTBOUND_HTTP_URL=https://your-clearinghouse-or-mock.example/transactions
# EDI_OUTBOUND_HTTP_TOKEN=
#
# When true, inbound webhook skips 277/835/997 claim updates if structural validation fails (artifact still stored).
# EDI_INBOUND_X12_VALIDATE_STRICT=true
#
# Optional pharmacy e-claims scaffold (NCPDP parallel path — see docs/CONNECTOR_STRATEGY.md Appendix B)
# NCPDP_CONNECTOR_ENABLED=1
#
# Optional: S3-compatible storage when payload > FHIR_IMPORT_MAX_INLINE_PAYLOAD_BYTES or EDI_BLOB_FORCE_EXTERNAL=true
# (FHIR import, CSV, clearinghouse X12, outbound 837 artifact). SHA-256 always on SourceArtifact; storageUri = s3://…
# EDI_S3_BUCKET=your-bucket
# EDI_S3_REGION=us-east-1
# EDI_S3_PREFIX=edi
# EDI_S3_ENDPOINT=   # R2 / MinIO URL if not AWS default
# EDI_S3_FORCE_PATH_STYLE=true
# EDI_S3_KMS_KEY_ID=
# EDI_BLOB_FORCE_EXTERNAL=false
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
#
# --- OpenAI — Pay “Explain charge” (calls https://api.openai.com when configured; no in-app “mock LLM”).
# Add your key to `.env.local` or `.env` in this directory (`apps/platform-app`). `npm run dev` does not read `.env.neon`
# (that file is only for Prisma/seed via `--env-file`).
#
# If OPENAI_API_KEY is unset or OPENAI_DISABLE_BILL_EXPLAIN=1, copy falls back to a deterministic template (not an API).
# For production PHI, plan on a BAA-covered inference route (see docs/ENGINEERING_BACKLOG.md).
#
# Provider: unset or openai → api.openai.com. azure → Azure OpenAI. auto → Azure if all AZURE_OPENAI_* set, else OpenAI.
# BILL_EXPLAIN_LLM_PROVIDER=openai
# BILL_EXPLAIN_LLM_PROVIDER=azure
# OPENAI_API_KEY=sk-...   # required for live Explain charge (see comment block above)
# OPENAI_CHAT_MODEL=gpt-4o-mini
# OPENAI_DISABLE_BILL_EXPLAIN=1
# OPENAI_BILL_EXPLAIN_MINIMAL_PAYLOAD=1
# INFERENCE_HIPAA_STRICT=1
#
# Support hub — optional LLM (same OPENAI_API_KEY); template fallback when unset or on error
# SUPPORT_ASSISTANT_LLM_ENABLED=1
# SUPPORT_ASSISTANT_OPENAI_MODEL=gpt-4o-mini
#
# Ship structured platform logs to your log stack (duplicate of stdout JSON lines)
# PLATFORM_LOG_WEBHOOK_URL=https://your-collector.example/ingest
# PLATFORM_LOG_WEBHOOK_SECRET=
#
# Azure OpenAI (private endpoint; typical HIPAA path with Microsoft BAA on your tenant)
# AZURE_OPENAI_ENDPOINT=https://YOUR_RESOURCE.openai.azure.com
# AZURE_OPENAI_API_KEY=...
# AZURE_OPENAI_DEPLOYMENT=your-chat-deployment-name
# AZURE_OPENAI_API_VERSION=2024-08-01-preview
#
# FHIR fixture import → Pay: optional FX overrides (JSON object, ISO code → USD per 1 major unit).
# Example: {"EUR":1.10,"GBP":1.29} merges over built-in pilot rates; lines without a rate are skipped.
# FHIR_IMPORT_FX_RATES_JSON={"EUR":1.10}
# When 1/true/yes: reject import if any claim line lacks an FX rate or no billable lines remain.
# FHIR_IMPORT_FX_STRICT=1
#
# Max bytes of raw bundle JSON to persist on SourceArtifact.textPayload (SHA-256 always stored). Default 524288.
# FHIR_IMPORT_MAX_INLINE_PAYLOAD_BYTES=524288
