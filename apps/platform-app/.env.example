# PostgreSQL (local: see repo-root docker-compose.yml)
DATABASE_URL="postgresql://anang:anang@localhost:5432/anang?schema=public"

# Demo sign-in (email + password form). Virtual email maps to tiers via /login UI.
DEMO_LOGIN_EMAIL="demo@anang.ai"
DEMO_LOGIN_PASSWORD="demo"
# Must match DEMO_LOGIN_EMAIL when using the tier picker (client bundle).
NEXT_PUBLIC_DEMO_LOGIN_EMAIL="demo@anang.ai"

# Optional: used when tightening demo cookies / future JWT
# SESSION_SECRET="generate-a-long-random-string"

# Public URLs (Vercel)
# NEXT_PUBLIC_ANANG_DOMAIN=anang.ai
# NEXT_PUBLIC_ANANG_APP_HOST=app.anang.ai
