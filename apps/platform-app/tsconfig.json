{
  "extends": "../../packages/tsconfig/nextjs.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@anang/ui": ["../../packages/ui/src/index.ts"],
      "@anang/brand": ["../../packages/brand/src/index.ts"],
      "@anang/config": ["../../packages/config/src/index.ts"],
      "@anang/types": ["../../packages/types/src/index.ts"]
    },
    "plugins": [{ "name": "next" }]
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
