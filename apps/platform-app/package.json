{
  "name": "@anang/platform-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3001",
    "build": "prisma generate && next build",
    "start": "next start --port 3001",
    "lint": "next lint",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:push:neon": "node --env-file=.env.neon ../../node_modules/prisma/build/index.js db push",
    "db:seed:neon": "node --env-file=.env.neon ../../node_modules/tsx/dist/cli.mjs prisma/seed.ts",
    "db:migrate": "prisma migrate dev",
    "db:seed": "npx tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "db:validate": "prisma validate",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@anang/brand": "*",
    "@anang/config": "*",
    "@anang/types": "*",
    "@anang/ui": "*",
    "@prisma/client": "^6.3.1",
    "next": "^15.1.8",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "devDependencies": {
    "@types/node": "^22.10.10",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.4",
    "@eslint/eslintrc": "^3.2.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.19.0",
    "eslint-config-next": "^15.1.8",
    "postcss": "^8.5.1",
    "prisma": "^6.3.1",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
